import psutil
import time
from datetime import datetime

CPU_THRESHOLD = 80
MEMORY_THRESHOLD = 80
DISK_THRESHOLD = 80

LOG_FILE = "system.log"


def log_message(message):
    with open(LOG_FILE, "a") as f:
        f.write(message + "\n")


def get_stats():
    cpu = psutil.cpu_percent(interval=1)
    memory = psutil.virtual_memory().percent
    disk = psutil.disk_usage('/').percent
    return cpu, memory, disk


def check_alerts(cpu, memory, disk):
    alerts = []

    if cpu > CPU_THRESHOLD:
        alerts.append(f"⚠️ High CPU Usage: {cpu}%")

    if memory > MEMORY_THRESHOLD:
        alerts.append(f"⚠️ High Memory Usage: {memory}%")

    if disk > DISK_THRESHOLD:
        alerts.append(f"⚠️ High Disk Usage: {disk}%")

    return alerts


def main():
    print("🔍 Running System Monitor (Press Ctrl+C to stop)\n")

    while True:
        cpu, memory, disk = get_stats()

        timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        log = f"{timestamp} | CPU: {cpu}% | Memory: {memory}% | Disk: {disk}%"

        print(log)
        log_message(log)

        alerts = check_alerts(cpu, memory, disk)
        for alert in alerts:
            print(alert)
            log_message(alert)

        time.sleep(5)


if __name__ == "__main__":
    main()
